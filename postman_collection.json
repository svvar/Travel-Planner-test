{
  "info": {
    "name": "Travel Planner API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "basic",
    "basic": [
      { "key": "password", "value": "secret", "type": "string" },
      { "key": "username", "value": "admin", "type": "string" }
    ]
  },
  "item": [
    {
      "name": "Projects",
      "item": [
        {
          "name": "Create Project",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Chicago Trip\",\n  \"description\": \"Visit the museum\",\n  \"start_date\": \"2026-05-20\",\n  \"places\": [\n    { \"external_id\": 129884, \"notes\": \"Must see!\" }\n  ]\n}"
            },
            "url": {"raw": "http://localhost:8000/projects/", "host": ["http://localhost:8000"], "path": ["projects", ""]}
          }
        },
        {
          "name": "Get Projects",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8000/projects/?skip=0&limit=10",
              "host": ["http://localhost:8000"],
              "path": ["projects", ""],
              "query": [{"key": "skip","value": "0"},{"key": "limit","value": "10"}]
            }
          }
        },
        {
          "name": "Get Project by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8000/projects/1",
              "host": ["http://localhost:8000"],
              "path": ["projects", "1"]
            }
          }
        },
        {
          "name": "Update Project",
          "request": {
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Chicago Trip Updated\",\n  \"description\": \"Visit the museum tomorrow\"\n}"
            },
            "url": {"raw": "http://localhost:8000/projects/1", "host": ["http://localhost:8000"], "path": ["projects", "1"]}
          }
        },
        {
          "name": "Delete Project",
          "request": {
            "method": "DELETE",
            "url": {"raw": "http://localhost:8000/projects/1", "host": ["http://localhost:8000"], "path": ["projects", "1"]}
          }
        }
      ]
    },
    {
      "name": "Places",
      "item": [
        {
          "name": "Add Place to Project",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"external_id\": 129885,\n  \"notes\": \"Another nice artwork\"\n}"
            },
            "url": {"raw": "http://localhost:8000/projects/1/places/", "host": ["http://localhost:8000"], "path": ["projects", "1", "places", ""]}
          }
        },
        {
          "name": "Get Project Places",
          "request": {
            "method": "GET",
            "url": {"raw": "http://localhost:8000/projects/1/places/", "host": ["http://localhost:8000"], "path": ["projects", "1", "places", ""]}
          }
        },
        {
          "name": "Get Place by ID",
          "request": {
            "method": "GET",
            "url": {"raw": "http://localhost:8000/projects/1/places/1", "host": ["http://localhost:8000"], "path": ["projects", "1", "places", "1"]}
          }
        },
        {
          "name": "Update Place (Mark Visited)",
          "request": {
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"notes\": \"Already seen it!\",\n  \"is_visited\": true\n}"
            },
            "url": {"raw": "http://localhost:8000/projects/1/places/1", "host": ["http://localhost:8000"], "path": ["projects", "1", "places", "1"]}
          }
        }
      ]
    }
  ]
}
